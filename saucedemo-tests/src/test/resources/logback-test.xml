<?xml version="1.0" encoding="UTF-8"?>
<!--
  logback configuration for saucedemo-tests.

  Same three appenders as platform-testframework (CONSOLE, FILE, ASYNC_LOGSTASH)
  plus extra suppressions for Playwright/Chromium and Cucumber internals.
-->
<configuration>

    <!-- ── CONSOLE ─────────────────────────────────────────────────────────── -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level [%X{testMethod:-?}] [%X{step:-}] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ── FILE ────────────────────────────────────────────────────────────── -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>target/platform-logs/saucedemo.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>target/platform-logs/saucedemo.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{ISO8601} %-5level run_id="%X{run_id:-}" testId="%X{testId:-}" traceId="%X{traceId:-}" step="%X{step:-}" logger="%logger{0}" - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ── LOGSTASH ─────────────────────────────────────────────────────────
         Ships JSON log events to Logstash → OpenSearch.
         Set LOGSTASH_HOST / LOGSTASH_PORT env vars to point at your instance.
         All MDC fields (run_id, testId, team_id, project_id, traceId, step)
         are included automatically at the JSON top level.
    ─────────────────────────────────────────────────────────────────────── -->
    <appender name="LOGSTASH" class="net.logstash.logback.appender.LogstashTcpSocketAppender">
        <destination>${LOGSTASH_HOST:-localhost}:${LOGSTASH_PORT:-5044}</destination>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeContext>false</includeContext>
            <includeMdc>true</includeMdc>
            <customFields>{"app":"test-execution","source":"saucedemo-tests"}</customFields>
        </encoder>
        <reconnectionDelay>5 seconds</reconnectionDelay>
        <keepAliveDuration>5 minutes</keepAliveDuration>
        <writeBufferSize>8192</writeBufferSize>
    </appender>

    <appender name="ASYNC_LOGSTASH" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="LOGSTASH"/>
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <neverBlock>true</neverBlock>
    </appender>

    <!-- Suppress Playwright / Chromium driver noise -->
    <logger name="com.microsoft.playwright"            level="WARN"/>
    <logger name="com.microsoft.playwright.impl"       level="WARN"/>

    <!-- Cucumber internals -->
    <logger name="io.cucumber"                         level="WARN"/>

    <!-- PicoContainer DI -->
    <logger name="org.picocontainer"                   level="WARN"/>

    <!-- Logstash appender's own connection-retry noise -->
    <logger name="net.logstash.logback"                level="WARN"/>

    <!-- Platform internals -->
    <logger name="com.platform.sdk.publisher"          level="INFO"/>
    <logger name="com.platform.testframework"          level="DEBUG"/>
    <logger name="io.opentelemetry"                    level="WARN"/>

    <!-- SauceDemo test classes -->
    <logger name="com.platform.tests.saucedemo"        level="INFO"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
        <appender-ref ref="ASYNC_LOGSTASH"/>
    </root>

</configuration>
