{
  "__inputs": [],
  "__requires": [
    { "type": "grafana",    "id": "grafana",    "name": "Grafana",    "version": "12.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "K6 real-time metrics streamed via -o experimental-prometheus-rw. Filter by team / project / environment tags.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "K6 History (Platform)",
      "url": "/d/k6-performance",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    }
  ],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Overview",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red",    "value": 2000 }
            ]
          },
          "unit": "ms",
          "mappings": []
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["mean"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Avg Response Time",
      "type": "stat",
      "targets": [
        {
          "expr": "avg(k6_http_req_duration_avg{team=~\"$team\", project=~\"$project\", environment=~\"$environment\"})",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red",    "value": 2000 }
            ]
          },
          "unit": "ms",
          "mappings": []
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["mean"] }, "colorMode": "background" },
      "title": "p95 Response Time",
      "type": "stat",
      "targets": [
        {
          "expr": "avg(k6_http_req_duration_p95{team=~\"$team\", project=~\"$project\", environment=~\"$environment\"})",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red",    "value": 0.05 }
            ]
          },
          "unit": "percentunit",
          "mappings": []
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["mean"] }, "colorMode": "background" },
      "title": "Error Rate",
      "type": "stat",
      "targets": [
        {
          "expr": "avg(k6_http_req_failed_rate{team=~\"$team\", project=~\"$project\", environment=~\"$environment\"})",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "unit": "short",
          "mappings": []
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["max"] }, "colorMode": "background" },
      "title": "Peak VUs",
      "type": "stat",
      "targets": [
        {
          "expr": "max(k6_vus{team=~\"$team\", project=~\"$project\", environment=~\"$environment\"})",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "purple", "value": null }]
          },
          "unit": "short",
          "mappings": []
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Total Requests",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(k6_http_reqs_total{team=~\"$team\", project=~\"$project\", environment=~\"$environment\"})",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 10,
      "title": "Virtual Users & Throughput",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2 }, "color": { "mode": "palette-classic" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "VUs" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } },
              { "id": "custom.fillOpacity", "value": 20 }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 11,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Virtual Users",
      "type": "timeseries",
      "targets": [
        {
          "expr": "max(k6_vus{team=~\"$team\", project=~\"$project\", environment=~\"$environment\"})",
          "legendFormat": "VUs",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2 }, "unit": "reqps", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 12,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(k6_http_reqs_total{team=~\"$team\", project=~\"$project\", environment=~\"$environment\"}[$__rate_interval]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 20,
      "title": "Response Time",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2 }, "unit": "ms", "color": { "mode": "palette-classic" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p95" },    "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p90" },    "properties": [{ "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "median" }, "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 15 },
      "id": 21,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Response Time Percentiles",
      "type": "timeseries",
      "targets": [
        {
          "expr": "avg(k6_http_req_duration_p95{team=~\"$team\", project=~\"$project\", environment=~\"$environment\"})",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "expr": "avg(k6_http_req_duration_p90{team=~\"$team\", project=~\"$project\", environment=~\"$environment\"})",
          "legendFormat": "p90",
          "refId": "B"
        },
        {
          "expr": "avg(k6_http_req_duration_med{team=~\"$team\", project=~\"$project\", environment=~\"$environment\"})",
          "legendFormat": "median",
          "refId": "C"
        },
        {
          "expr": "avg(k6_http_req_duration_avg{team=~\"$team\", project=~\"$project\", environment=~\"$environment\"})",
          "legendFormat": "avg",
          "refId": "D"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2 }, "unit": "ms", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 15 },
      "id": 22,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Response Time by Group",
      "type": "timeseries",
      "targets": [
        {
          "expr": "avg by (group) (k6_http_req_duration_avg{team=~\"$team\", project=~\"$project\", environment=~\"$environment\", group!=\"\"})",
          "legendFormat": "{{group}}",
          "refId": "A"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "id": 30,
      "title": "Errors",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2 },
          "unit": "percentunit",
          "color": { "mode": "fixed", "fixedColor": "#F2495C" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red",    "value": 0.05 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "id": 31,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Error Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "avg(k6_http_req_failed_rate{team=~\"$team\", project=~\"$project\", environment=~\"$environment\"})",
          "legendFormat": "error rate",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2 }, "unit": "ms", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "id": 32,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Connection & Waiting Time",
      "type": "timeseries",
      "targets": [
        {
          "expr": "avg(k6_http_req_connecting_avg{team=~\"$team\", project=~\"$project\", environment=~\"$environment\"})",
          "legendFormat": "connecting",
          "refId": "A"
        },
        {
          "expr": "avg(k6_http_req_waiting_avg{team=~\"$team\", project=~\"$project\", environment=~\"$environment\"})",
          "legendFormat": "waiting (TTFB)",
          "refId": "B"
        },
        {
          "expr": "avg(k6_http_req_receiving_avg{team=~\"$team\", project=~\"$project\", environment=~\"$environment\"})",
          "legendFormat": "receiving",
          "refId": "C"
        }
      ]
    }

  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["k6", "performance", "realtime", "prometheus"],
  "templating": {
    "list": [
      {
        "name": "team",
        "label": "Team",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(k6_vus, team)", "refId": "team" },
        "definition": "label_values(k6_vus, team)",
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 2,
        "sort": 1,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "project",
        "label": "Project",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(k6_vus{team=~\"$team\"}, project)", "refId": "project" },
        "definition": "label_values(k6_vus{team=~\"$team\"}, project)",
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 2,
        "sort": 1,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "environment",
        "label": "Environment",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(k6_vus, environment)", "refId": "environment" },
        "definition": "label_values(k6_vus, environment)",
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 2,
        "sort": 1,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "K6 Real-time Metrics",
  "uid": "k6-realtime",
  "version": 2
}
