    },

    {
      "id": 71,
      "type": "table",
      "title": "Recent Executions",
      "description": "Last 20 test runs with team, project, and result summary.",
      "gridPos": { "x": 0, "y": 60, "w": 24, "h": 8 },
      "datasource": { "type": "postgres", "uid": "platform-postgres" },
      "options": { "footer": { "show": false }, "showHeader": true },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "Run ID" }, "properties": [{ "id": "custom.width", "value": 240 }] },
          { "matcher": { "id": "byName", "options": "Team" }, "properties": [{ "id": "custom.width", "value": 120 }] },
          { "matcher": { "id": "byName", "options": "Project" }, "properties": [{ "id": "custom.width", "value": 140 }] },
          { "matcher": { "id": "byName", "options": "Source" }, "properties": [{ "id": "custom.width", "value": 130 }] },
          { "matcher": { "id": "byName", "options": "Env" }, "properties": [{ "id": "custom.width", "value": 90 }] },
          { "matcher": { "id": "byName", "options": "Total" }, "properties": [{ "id": "custom.width", "value": 60 }] },
          { "matcher": { "id": "byName", "options": "Passed" }, "properties": [
            { "id": "custom.width", "value": 65 },
            { "id": "custom.displayMode", "value": "color-text" },
            { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
          ]},
          { "matcher": { "id": "byName", "options": "Failed" }, "properties": [
            { "id": "custom.width", "value": 60 },
            { "id": "custom.displayMode", "value": "color-text" },
            { "id": "color", "value": { "mode": "thresholds" } },
            { "id": "thresholds", "value": { "mode": "absolute", "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]}}
          ]}
        ]
      },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT te.run_id AS \"Run ID\", t.name AS \"Team\", p.name AS \"Project\", te.source_format AS \"Source\", te.environment AS \"Env\", te.total_tests AS \"Total\", te.passed AS \"Passed\", te.failed AS \"Failed\", te.skipped AS \"Skipped\", te.executed_at AS \"Executed At\" FROM test_executions te JOIN projects p ON p.id = te.project_id JOIN teams t ON t.id = p.team_id WHERE $__timeFilter(te.executed_at) AND ('$team' = 'All' OR t.slug = '$team') AND ('$project' = 'All' OR p.slug = '$project') ORDER BY te.executed_at DESC LIMIT 20",
          "format": "table"
        }
      ]
    }

