<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    TestNG suite for https://www.saucedemo.com
    Delegates test discovery to AbstractTestNGCucumberTests which creates one
    TestNG test per Cucumber scenario found in src/test/resources/features/.

    Run all scenarios:        mvn test
    Run smoke only:           mvn test -Dcucumber.filter.tags="@smoke"
    Watch browser:            mvn test -Dheadless=false
-->
<suite name="SauceDemo Suite" verbose="1">

    <test name="SauceDemo Cucumber Scenarios" preserve-order="true">
        <classes>
            <class name="com.example.saucedemo.runner.CucumberRunner"/>
        </classes>
    </test>

</suite>
