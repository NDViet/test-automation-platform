<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
         https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>4.0.6</version>
        <relativePath/>
    </parent>

    <groupId>org.ndviet</groupId>
    <artifactId>test-automation-platform</artifactId>
    <version>1.0.0-SNAPSHOT</version>
    <packaging>pom</packaging>
    <name>Test Automation Platform</name>
    <description>Cross-team test automation quality intelligence platform</description>

    <modules>
        <module>platform-common</module>
        <module>platform-storage</module>
        <module>platform-core</module>
        <module>platform-security</module>
        <module>platform-llm</module>
        <module>platform-ingestion</module>
        <module>platform-adapters</module>
        <module>platform-analytics</module>
        <module>platform-integration</module>
        <module>platform-integration-config</module>
        <module>platform-ai</module>
        <module>platform-testkit</module>
        <module>platform-portal</module>
        <module>platform-agent</module>
    </modules>

    <properties>
        <java.version>21</java.version>
        <maven.compiler.source>21</maven.compiler.source>
        <maven.compiler.target>21</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

        <!-- CVE overrides: bump Spring Boot 4.0.6 managed transitive deps to patched
             releases. Re-check with Trivy after any Spring Boot upgrade and drop any
             override the new BOM already satisfies. -->
        <tomcat.version>11.0.22</tomcat.version>            <!-- CVE-2026-41293/43512/43515 (CRITICAL) + more -->
        <netty.version>4.2.15.Final</netty.version>          <!-- CVE-2026-44249/45416/50010/45674/47691 + codec CVEs -->
        <jackson-bom.version>3.1.4</jackson-bom.version>      <!-- Jackson 3: CVE-2026-54512/54513 -->
        <jackson-2-bom.version>2.22.0</jackson-2-bom.version> <!-- Jackson 2: CVE-2026-54512/54513 (>= 2.21.4 patch) -->
        <postgresql.version>42.7.11</postgresql.version>     <!-- CVE-2026-42198 -->

        <!-- Dependency versions -->
        <spring-kafka.version>4.0.6</spring-kafka.version>
        <!-- Pinned to match the db-migrate container image (flyway/flyway:12.9) so the migration
             job and the app-side flyway-core compute the same V1 checksum. Overrides the Spring
             Boot 4.0.6 BOM default (11.8.2). -->
        <flyway.version>12.9.0</flyway.version>
        <springdoc.version>2.8.8</springdoc.version>
        <testcontainers.version>1.21.1</testcontainers.version>
        <wiremock.version>3.13.0</wiremock.version>
        <jaxb.version>4.0.5</jaxb.version>
        <logstash-encoder.version>8.1</logstash-encoder.version>
        <resilience4j.version>2.3.0</resilience4j.version>
        <aspectj.version>1.9.22.1</aspectj.version>
        <allure.version>2.29.1</allure.version>
        <aws-sdk.version>2.30.0</aws-sdk.version>
        <langchain4j.version>1.0.0</langchain4j.version>
    </properties>

    <dependencyManagement>
        <dependencies>
            <!-- Internal modules -->
            <dependency>
                <groupId>org.ndviet</groupId>
                <artifactId>platform-common</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>org.ndviet</groupId>
                <artifactId>platform-core</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>org.ndviet</groupId>
                <artifactId>platform-llm</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>org.ndviet</groupId>
                <artifactId>platform-adapter-java</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>org.ndviet</groupId>
                <artifactId>platform-testkit-java</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>org.ndviet</groupId>
                <artifactId>platform-integration-config</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>org.ndviet</groupId>
                <artifactId>platform-storage</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>org.ndviet</groupId>
                <artifactId>platform-agent</artifactId>
                <version>${project.version}</version>
            </dependency>

            <!-- AWS SDK v2 BOM — covers S3, S3 Transfer Manager, and all service clients.
                 Used by platform-storage; compatible with MinIO, AWS S3, and GCS XML API. -->
            <dependency>
                <groupId>software.amazon.awssdk</groupId>
                <artifactId>bom</artifactId>
                <version>${aws-sdk.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>

            <!-- LangChain4j BOM — agent layer + OpenAI-compatible client (used against LiteLLM).
                 Imported by platform-llm; aligns all langchain4j artifact versions. -->
            <dependency>
                <groupId>dev.langchain4j</groupId>
                <artifactId>langchain4j-bom</artifactId>
                <version>${langchain4j.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>

            <!-- Spring Kafka -->
            <dependency>
                <groupId>org.springframework.kafka</groupId>
                <artifactId>spring-kafka</artifactId>
                <version>${spring-kafka.version}</version>
            </dependency>
            <dependency>
                <groupId>org.springframework.kafka</groupId>
                <artifactId>spring-kafka-test</artifactId>
                <version>${spring-kafka.version}</version>
                <scope>test</scope>
            </dependency>

            <!-- Flyway -->
            <dependency>
                <groupId>org.flywaydb</groupId>
                <artifactId>flyway-core</artifactId>
                <version>${flyway.version}</version>
            </dependency>
            <dependency>
                <groupId>org.flywaydb</groupId>
                <artifactId>flyway-database-postgresql</artifactId>
                <version>${flyway.version}</version>
            </dependency>

            <!-- SpringDoc OpenAPI -->
            <dependency>
                <groupId>org.springdoc</groupId>
                <artifactId>springdoc-openapi-starter-webmvc-ui</artifactId>
                <version>${springdoc.version}</version>
            </dependency>
            <dependency>
                <groupId>org.springdoc</groupId>
                <artifactId>springdoc-openapi-starter-webflux-ui</artifactId>
                <version>${springdoc.version}</version>
            </dependency>

            <!-- Testcontainers BOM -->
            <dependency>
                <groupId>org.testcontainers</groupId>
                <artifactId>testcontainers-bom</artifactId>
                <version>${testcontainers.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>

            <!-- WireMock -->
            <dependency>
                <groupId>org.wiremock</groupId>
                <artifactId>wiremock-standalone</artifactId>
                <version>${wiremock.version}</version>
                <scope>test</scope>
            </dependency>

            <!-- JAXB (JUnit XML / TestNG parsing) -->
            <dependency>
                <groupId>jakarta.xml.bind</groupId>
                <artifactId>jakarta.xml.bind-api</artifactId>
                <version>${jaxb.version}</version>
            </dependency>
            <dependency>
                <groupId>com.sun.xml.bind</groupId>
                <artifactId>jaxb-impl</artifactId>
                <version>${jaxb.version}</version>
            </dependency>

            <!-- Logstash JSON encoder -->
            <dependency>
                <groupId>net.logstash.logback</groupId>
                <artifactId>logstash-logback-encoder</artifactId>
                <version>${logstash-encoder.version}</version>
            </dependency>

            <!-- Resilience4j -->
            <dependency>
                <groupId>io.github.resilience4j</groupId>
                <artifactId>resilience4j-spring-boot3</artifactId>
                <version>${resilience4j.version}</version>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <!--
      Inherited by every module. Byte Buddy's agent is preloaded into the test JVM (see the
      surefire argLine) so Mockito's inline mock maker never self-attaches; declaring it here as a
      test dependency lets surefire resolve ${net.bytebuddy:byte-buddy-agent:jar} to its path.
      Version is managed by the Spring Boot BOM.
    -->
    <dependencies>
        <dependency>
            <groupId>net.bytebuddy</groupId>
            <artifactId>byte-buddy-agent</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <distributionManagement>
        <repository>
            <id>github</id>
            <name>GitHub Packages</name>
            <url>https://maven.pkg.github.com/${env.GITHUB_REPOSITORY}</url>
        </repository>
    </distributionManagement>

    <build>
        <pluginManagement>
            <plugins>
                <plugin>
                    <groupId>org.springframework.boot</groupId>
                    <artifactId>spring-boot-maven-plugin</artifactId>
                </plugin>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-compiler-plugin</artifactId>
                    <configuration>
                        <source>21</source>
                        <target>21</target>
                        <compilerArgs>
                            <arg>-parameters</arg>
                        </compilerArgs>
                    </configuration>
                </plugin>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-surefire-plugin</artifactId>
                    <configuration>
                        <!--
                          Preload Byte Buddy's agent so Mockito's inline mock maker doesn't have to
                          self-attach at runtime. JDK 21 self-attach via an external helper process is
                          fragile (and can be blocked by EDR/AV), and is deprecated for removal — the
                          official Mockito guidance for JDK 21+ is to load the agent up front.
                        -->
                        <argLine>-XX:+EnableDynamicAgentLoading -javaagent:${net.bytebuddy:byte-buddy-agent:jar}</argLine>
                    </configuration>
                </plugin>
            </plugins>
        </pluginManagement>

        <!--
          Spotless formats all Java sources with google-java-format.
            mvn spotless:apply   → reformat in place
            mvn spotless:check   → fail if any file is not formatted (use in CI)
          `check` is intentionally NOT bound to the build lifecycle yet, so existing
          builds keep working until the first `mvn spotless:apply` pass. To enforce
          formatting on every build, uncomment the <executions> block below.
        -->
        <plugins>
            <plugin>
                <groupId>com.diffplug.spotless</groupId>
                <artifactId>spotless-maven-plugin</artifactId>
                <version>2.44.5</version>
                <configuration>
                    <java>
                        <googleJavaFormat>
                            <version>1.27.0</version>
                            <style>GOOGLE</style>
                            <reflowLongStrings>true</reflowLongStrings>
                        </googleJavaFormat>
                        <removeUnusedImports/>
                        <importOrder/>
                        <trimTrailingWhitespace/>
                        <endWithNewline/>
                    </java>
                </configuration>
                <!--
                <executions>
                    <execution>
                        <goals>
                            <goal>check</goal>
                        </goals>
                    </execution>
                </executions>
                -->
            </plugin>
            <!--
              Resolves dependency artifacts to ${groupId:artifactId:type} properties before tests,
              so the surefire argLine can point -javaagent at byte-buddy-agent's jar (see above).
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-dependency-plugin</artifactId>
                <executions>
                    <execution>
                        <id>resolve-test-agent-paths</id>
                        <phase>initialize</phase>
                        <goals>
                            <goal>properties</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

    <!--
      One-shot formatting for the whole repo:
          mvn -Pformat process-sources
      Runs spotless:apply on every module's Java, and (in platform-portal)
      Prettier on the React/TS frontend. See platform-portal/pom.xml for the
      frontend half of this profile.
    -->
    <profiles>
        <profile>
            <id>format</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>com.diffplug.spotless</groupId>
                        <artifactId>spotless-maven-plugin</artifactId>
                        <executions>
                            <execution>
                                <id>spotless-apply</id>
                                <phase>process-sources</phase>
                                <goals>
                                    <goal>apply</goal>
                                </goals>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>
</project>
