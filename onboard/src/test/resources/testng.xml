<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    TestNG suite for https://the-internet.herokuapp.com
    Runs all test classes sequentially (one browser per test method).

    Run smoke-only:  mvn test -Dgroups=smoke
    Run all:         mvn test
-->
<suite name="The-Internet Suite" verbose="1">

    <test name="Login" preserve-order="true">
        <classes>
            <class name="com.example.theinternet.tests.LoginTest"/>
        </classes>
    </test>

    <test name="Checkboxes" preserve-order="true">
        <classes>
            <class name="com.example.theinternet.tests.CheckboxTest"/>
        </classes>
    </test>

    <test name="Dynamic Loading" preserve-order="true">
        <classes>
            <class name="com.example.theinternet.tests.DynamicLoadingTest"/>
        </classes>
    </test>

    <test name="Edge Cases" preserve-order="true">
        <classes>
            <class name="com.example.theinternet.tests.EdgeCaseTest"/>
        </classes>
    </test>

</suite>
